{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IntentClassifierOutput",
  "type": "object",
  "properties": {
    "intent": {
      "type": "string",
      "enum": ["informational", "verify_state", "execute"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "reason_tokens": {
      "type": "array",
      "items": {"type": "string"}
    },
    "source": {"type": "string"}
  },
  "required": ["intent", "confidence", "reason_tokens", "source"],
  "additionalProperties": false
}
