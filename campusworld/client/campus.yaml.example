# CampusWorld CLI 客户端配置示例
# 复制此文件为 campus.yaml 或 ~/.config/campus/config.yaml

# 服务端连接配置
server:
  host: "localhost"
  port: 8000
  use_ssl: false

# 认证配置
auth:
  token_file: "~/.config/campus/token"
  default_user: "guest"

# 终端 UI 配置
terminal:
  theme: "default"
  font_size: 14
  font_family: "monospace"

# 命令补全配置
completion:
  enabled: true
  fuzzy_match: true

# 命令历史配置
history:
  enabled: true
  size: 1000
  file: "~/.local/share/campus/history"

# 日志配置
logging:
  level: "info"
  file: "~/.local/share/campus/logs/campus.log"
