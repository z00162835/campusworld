# CampusWorld Frontend Environment Variables Example
# 复制此文件为 .env 并根据需要修改

# API Configuration
VITE_API_BASE_URL=http://localhost:8000/api/v1

# HTTPS Configuration (for production)
# Set to 'true' to enable HTTPS for development
VITE_USE_HTTPS=false
# SSL certificate paths (required when VITE_USE_HTTPS=true)
# VITE_SSL_CERT_PATH=/path/to/cert.pem
# VITE_SSL_KEY_PATH=/path/to/key.pem

# App Configuration
VITE_APP_TITLE=CampusWorld
VITE_APP_VERSION=0.1.0
VITE_APP_ENVIRONMENT=development
VITE_ENABLE_DEBUG=true
